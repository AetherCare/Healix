# MediVault AI — Environment Configuration
# Copy to .env and fill in values before running.

# Application
APP_NAME="MediVault AI"
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-secret-key-at-least-32-chars
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# CORS — comma-separated origins; use * in development for ngrok/remote frontend
ALLOWED_ORIGINS=*

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://medivault:medivault_secret@localhost:5432/medivault

# Redis (Celery broker + rate limiting)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# JWT
JWT_SECRET_KEY=change-me-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# File Storage
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage
STORAGE_MAX_FILE_SIZE_MB=25
# AWS S3 (when STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1

# LLM Provider — groq | openai | anthropic
LLM_PROVIDER=groq
# Add your Groq API key here for AI chat and report analysis:
GROQ_API_KEY=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
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Whisper (Groq-hosted Whisper)
WHISPER_MODEL=whisper-large-v3

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_data
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Tunnel
TUNNEL_URL_FILE=.tunnel_url

# Rate limiting
AUTH_RATE_LIMIT=10/minute
